! URxvt apperance

URxvt.scrollBar: false

URxvt.font: xft:mononoki:pixelsize=12:antialias=true
URxvt.boldfont: xft:mononoki:bold:pixelsize=12:antialias=true
URxvt.letterSpace: 0
URxvt.lineSpace: 0
URxvt.geometry: 92x24
URxvt.internalBorder: 6
URxvt.cursorBlink: true
URxvt.cursorUnderline: false
URxvt.saveline: 2048

URxvt.transparent: true
URxvt.shading: 35

!!URxvt.keysym.M-c: perl:clipboard:copy
!!URxvt.keysym.M-v: perl:clipboard:paste
!!URxvt.keysym.M-C-v: perl:clipboard:paste_escaped

! URxvt colour
*.foreground: #ffffff
*.background: #191b1e
*.cursorColor: #afbfbf

! black
*.color0: #292b32
*.color8: #5f6368

! red
*.color1: #f03829
*.color9: #f03829

! green
*.color2: #22b50f
*.color10: #22b50f

! yellow
*.color3: #fbb205
*.color11: #fbb205

! blue
*.color4: #429af4
*.color12: #429af4

! magenta
*.color5: #ea52d2
*.color13: #ea52d2

! cyan
*.color6: #24c1e0
*.color14: #24c1e0

! white
*.color7: #ffffff
*.color15: #ffffff

! extensions

! URxvt.perl-ext-common: default,clipboard
! URxvt.copyCommand: xclip -i -selection clipboard
! URxvt.pasteCommand: xclip -o -selection clipboard
